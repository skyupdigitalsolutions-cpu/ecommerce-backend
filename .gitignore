# ---- Dependencies ----
node_modules/

# ---- Environment / secrets (NEVER commit these) ----
.env
.env.local
.env.*.local
.env.development
.env.production
# keep the template tracked
!.env.example

# ---- Logs ----
logs/*
!logs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Uploads (files go to Cloudinary, not the repo) ----
uploads/*
!uploads/.gitkeep

# ---- Build / coverage output ----
dist/
build/
coverage/
.cache/

# ---- OS files ----
.DS_Store
Thumbs.db

# ---- Editor / IDE ----
.vscode/
.idea/
*.swp