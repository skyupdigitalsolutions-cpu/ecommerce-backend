# ---- Server ----
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/ecommerce

# ---- JWT (bearer access token + refresh token) ----
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES=7d

# ---- Cloudinary (image uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Brevo (transactional email) ----
BREVO_API_KEY=
EMAIL_FROM_NAME=My Store
EMAIL_FROM_ADDRESS=no-reply@mystore.com

# ---- Redis (used in later phases: cache, OTP, BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Razorpay (payment - later phase) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
